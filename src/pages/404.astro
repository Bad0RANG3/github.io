---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="你访问的页面不存在。">
  <div class="mx-auto max-w-2xl py-24 text-center">
    <div class="glass-card p-10">
      <p class="text-sm font-medium uppercase tracking-[0.3em] text-pink-600 dark:text-pink-300">404</p>
      <h1 class="mt-4 text-4xl font-bold text-gray-900 dark:text-white">页面未找到</h1>
      <p class="mt-3 text-gray-500 dark:text-gray-400">你访问的内容可能已经移动，或者链接本身有误。</p>
      <a href="/" class="mt-8 inline-flex rounded-full bg-gradient-to-r from-pink-500 to-purple-500 px-6 py-3 font-medium text-white transition hover:shadow-lg hover:shadow-pink-500/25">
        返回首页
      </a>
    </div>
  </div>
</BaseLayout>
