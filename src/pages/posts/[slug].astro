---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/blog/PostMeta.astro';
import TagList from '../../components/blog/TagList.astro';
import { getPublishedPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const isResourceList = post.data.category === '资源清单';
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.cover}
  type="article"
  publishedTime={post.data.date.toISOString()}
  updatedTime={post.data.updatedDate?.toISOString()}
>
  <article class:list={['mx-auto', isResourceList ? 'max-w-5xl' : 'max-w-3xl']}>
    <header class="mb-10 text-center">
      <div data-reveal class="reveal mb-4 flex flex-wrap items-center justify-center gap-2">
        {post.data.featured && (
          <span class="rounded-full bg-gradient-to-r from-pink-500 to-purple-500 px-2.5 py-1 text-xs font-medium text-white shadow-[0_8px_24px_rgba(236,72,153,0.22)]">
            精选文章
          </span>
        )}
        {post.data.category && (
          <span class="rounded-full border border-gray-200 px-2.5 py-1 text-xs text-gray-500 dark:border-gray-700 dark:text-gray-400">
            {post.data.category}
          </span>
        )}
      </div>
      <h1 data-reveal class="reveal mb-4 text-3xl font-bold leading-tight text-gray-900 dark:text-white md:text-4xl" style="--reveal-delay:90ms">
        {post.data.title}
      </h1>
      <p data-reveal class="reveal mx-auto mb-4 max-w-2xl text-gray-600 dark:text-gray-300" style="--reveal-delay:150ms">
        {post.data.description}
      </p>
      <div class="space-y-4">
        <div data-reveal class="reveal" style="--reveal-delay:210ms">
          <PostMeta date={post.data.date} updatedDate={post.data.updatedDate} centered long />
        </div>
        <div data-reveal class="reveal flex justify-center" style="--reveal-delay:260ms">
          <TagList tags={post.data.tags} />
        </div>
      </div>
    </header>

    {isResourceList && (
      <div data-reveal class="glass-card reveal mb-8 p-5 sm:p-6" style="--reveal-delay:300ms">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Guide</p>
            <h2 class="mt-2 text-lg font-semibold text-gray-900 dark:text-white">这篇文章怎么读更省时间</h2>
            <p class="mt-2 max-w-3xl text-sm leading-7 text-gray-600 dark:text-gray-400">
              这是一篇偏“资源导航”型长文，推荐先看上方的快速入口，再按自己的场景跳到对应分区；如果你只想找平替，优先看“成本 / 限制”和“可替代方案”两列。
            </p>
          </div>
          <div class="rounded-2xl border border-pink-200/60 bg-pink-50/70 px-4 py-3 text-left text-sm text-pink-600 shadow-[0_10px_24px_rgba(236,72,153,0.08)] dark:border-purple-500/20 dark:bg-purple-950/30 dark:text-purple-300">
            建议桌面端阅读，表格更完整。
          </div>
        </div>
      </div>
    )}

    {post.data.cover && (
      <img data-reveal src={post.data.cover} alt={post.data.title} class="reveal mb-8 w-full rounded-3xl border border-gray-100 object-cover shadow-[0_24px_60px_rgba(15,23,42,0.12)] dark:border-gray-800" style="--reveal-delay:320ms" />
    )}

    <div data-reveal class:list={['prose-content reveal', isResourceList && 'prose-resource-list']} style="--reveal-delay:220ms">
      <Content />
    </div>
  </article>
</BaseLayout>
