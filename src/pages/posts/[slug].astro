---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-none">
    <header class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
        {post.data.title}
      </h1>
      <time class="text-sm text-gray-500 dark:text-gray-400">
        {formattedDate}
      </time>
    </header>

    <div class="prose-slate dark:prose-invert dark:text-gray-300">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .prose :global(h1) {
    @apply text-2xl font-bold text-gray-900 dark:text-white mt-8 mb-4;
  }
  .prose :global(h2) {
    @apply text-xl font-semibold text-gray-900 dark:text-white mt-6 mb-3;
  }
  .prose :global(h3) {
    @apply text-lg font-semibold text-gray-900 dark:text-white mt-4 mb-2;
  }
  .prose :global(p) {
    @apply leading-relaxed mb-4 text-gray-700 dark:text-gray-300;
  }
  .prose :global(a) {
    @apply text-blue-500 hover:text-purple-500 underline;
  }
  .prose :global(code) {
    @apply bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-sm;
  }
  .prose :global(pre) {
    @apply bg-gray-900 text-gray-100 p-4 rounded-lg overflow-x-auto my-4;
  }
  .prose :global(pre code) {
    @apply bg-transparent p-0 text-inherit;
  }
  .prose :global(ul) {
    @apply list-disc pl-6 mb-4 space-y-1;
  }
  .prose :global(ol) {
    @apply list-decimal pl-6 mb-4 space-y-1;
  }
  .prose :global(li) {
    @apply text-gray-700 dark:text-gray-300;
  }
  .prose :global(blockquote) {
    @apply border-l-4 border-blue-500 pl-4 italic text-gray-600 dark:text-gray-400 my-4;
  }
  .prose :global(hr) {
    @apply border-gray-200 dark:border-gray-700 my-8;
  }
  .prose :global(strong) {
    @apply font-semibold;
  }
  .prose :global(img) {
    @apply max-w-full rounded-lg my-4;
  }
  .prose :global(table) {
    @apply w-full border-collapse my-4;
  }
  .prose :global(th) {
    @apply border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 p-2 text-left;
  }
  .prose :global(td) {
    @apply border border-gray-200 dark:border-gray-700 p-2;
  }
</style>
