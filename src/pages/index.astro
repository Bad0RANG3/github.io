---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
}
---

<BaseLayout title="首页" description="分享我在软件开发、技术和生活中的想法与经验。">
  <div class="min-h-[70vh] flex flex-col justify-center items-start pb-12">
    <div class="space-y-6 max-w-2xl">
      <p class="text-lg text-gray-600 dark:text-gray-400">开发者</p>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white">
        你好👋 我是<span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Bad0RANG3</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        喜欢在计算机方面折腾的一个普普通通的菜鸟，更倾向于视频特效的制作。
      </p>
      <a href="/about" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-primary to-secondary text-white font-medium hover:shadow-lg hover:shadow-primary/25 transition-all duration-300">
        了解更多
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>

  <section class="py-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 flex items-center gap-3">
      <span class="w-1 h-6 bg-gradient-to-b from-primary to-secondary rounded-full"></span>
      文章
    </h2>
    {sortedPosts.length === 0 ? (
      <div class="text-center py-12 text-gray-500 dark:text-gray-400">
        还没有文章哦
      </div>
    ) : (
      <div class="grid gap-6">
        {sortedPosts.map((post) => (
          <a href={`/posts/${post.slug}`} class="group block p-6 rounded-2xl border border-gray-100 dark:border-gray-800 hover:border-primary/30 dark:hover:border-secondary/30 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm hover:shadow-xl hover:shadow-primary/5 transition-all duration-300">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-primary dark:group-hover:text-secondary transition-colors mb-2">
                  {post.data.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 line-clamp-2 mb-3">
                  {post.data.description}
                </p>
                <time class="text-sm text-gray-400">{formatDate(post.data.date)}</time>
              </div>
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-r from-primary/10 to-secondary/10 flex items-center justify-center text-primary dark:text-secondary group-hover:from-primary/20 group-hover:to-secondary/20 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
