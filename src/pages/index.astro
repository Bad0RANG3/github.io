---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<BaseLayout title="欢迎光临全家博客">
  <section class="relative mb-16 h-[500px] rounded-3xl overflow-hidden">
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
      <source src="/src/bgvedio.webm" type="video/webm">
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <img src="/src/wxjb.png" alt="无限进步" class="w-1/2 max-w-md z-10">
    </div>
    <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">欢迎来到我的博客</h1>
      <p class="text-lg text-white/80">分享我在软件开发、技术和生活中的想法与经验。</p>
    </div>
  </section>

  <section>
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-8 flex items-center gap-3">
      <span class="w-1 h-8 bg-gradient-to-b from-blue-500 to-purple-500 rounded-full"></span>
      最新文章
    </h2>
    {sortedPosts.length === 0 ? (
      <div class="text-center py-20 bg-white dark:bg-[#1a1a2e] rounded-2xl border border-slate-200 dark:border-slate-700/50">
        <p class="text-slate-500 dark:text-slate-400 mb-4">还没有文章哦。</p>
      </div>
    ) : (
      <div class="grid gap-5">
        {sortedPosts.map((post, index) => (
          <a href={`/posts/${post.slug}`} class="group block bg-white dark:bg-[#1a1a2e] rounded-2xl p-6 border border-slate-200/80 dark:border-slate-700/50 hover:border-blue-500/50 dark:hover:border-purple-500/50 transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/10 dark:hover:shadow-purple-500/10 hover:-translate-y-0.5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-3 group-hover:text-blue-500 dark:group-hover:text-purple-400 transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-slate-600 dark:text-slate-400 line-clamp-2 mb-4">
                  {post.data.description}
                </p>
                <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-500">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <span>{formatDate(post.data.date)}</span>
                </div>
              </div>
              <div class="flex items-center gap-1 text-blue-500 dark:text-purple-400 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
                阅读全文
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
