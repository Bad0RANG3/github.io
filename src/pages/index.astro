---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
}
---

<BaseLayout title="首页">
  <div class="space-y-8">
    {sortedPosts.length === 0 ? (
      <div class="text-center py-20 text-gray-500 dark:text-gray-400">
        还没有文章哦
      </div>
    ) : (
      <div class="grid gap-4">
        {sortedPosts.map((post) => (
          <a href={`/posts/${post.slug}`} class="group block p-4 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-primary/50 dark:hover:border-secondary/50 transition-all hover:shadow-md dark:hover:shadow-primary/10">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary dark:group-hover:text-secondary transition-colors mb-1">
                  {post.data.title}
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-1 mb-2">
                  {post.data.description}
                </p>
                <time class="text-xs text-gray-400">{formatDate(post.data.date)}</time>
              </div>
              <div class="text-primary dark:text-secondary text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                →
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
