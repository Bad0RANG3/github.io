---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formattedDate = (date: Date) => date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---

<BaseLayout title="首页" description="分享我在软件开发、技术和生活中的想法与经验。">
  <div class="fixed inset-0 z-[-1] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-pink-300 via-purple-300 to-pink-400 dark:from-pink-900 dark:via-purple-900 dark:to-pink-950" />
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30" />
  </div>

  <div class="min-h-[70vh] flex flex-col justify-center items-start pb-12">
    <div class="space-y-6 max-w-2xl">
      <p class="text-lg text-pink-700 dark:text-pink-300 font-medium">开发者</p>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white">
        你好👋 我是<span class="bg-gradient-to-r from-pink-500 to-purple-500 bg-clip-text text-transparent">Bad0RANG3</span>
      </h1>
      <p class="text-lg text-gray-700 dark:text-gray-200 leading-relaxed">
        喜欢在计算机方面折腾的一个普普通通的菜鸟，更倾向于视频特效的制作。
      </p>
      <a href="/about" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 text-white font-medium hover:shadow-lg hover:shadow-pink-500/25 transition-all duration-300">
        了解更多
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>

  <section class="py-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 flex items-center gap-3">
      <span class="w-1 h-6 bg-gradient-to-b from-pink-500 to-purple-500 rounded-full"></span>
      文章
    </h2>
    {sortedPosts.length === 0 ? (
      <div class="text-center py-12 text-gray-500 dark:text-gray-400">
        还没有文章哦
      </div>
    ) : (
      <div class="grid gap-6">
        {sortedPosts.map((post) => (
          <a href={`/posts/${post.slug}`} class="group block p-6 rounded-2xl border border-gray-100 dark:border-gray-800 hover:border-pink-300/50 dark:hover:border-purple-500/50 bg-white/70 dark:bg-gray-900/70 backdrop-blur-sm hover:shadow-xl hover:shadow-pink-500/10 transition-all duration-300">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-pink-500 dark:group-hover:text-purple-400 transition-colors mb-2">
                  {post.data.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 line-clamp-2 mb-3">
                  {post.data.description}
                </p>
                <time class="text-sm text-gray-400">{formattedDate(post.data.date)}</time>
              </div>
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-r from-pink-500/10 to-purple-500/10 flex items-center justify-center text-pink-500 dark:text-purple-400 group-hover:from-pink-500/20 group-hover:to-purple-500/20 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
