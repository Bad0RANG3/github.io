---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/blog/PostCard.astro';
import { siteConfig } from '../config/site';
import { getPublishedPosts } from '../lib/content';

const posts = await getPublishedPosts();
const featuredPosts = posts.filter((post) => post.data.featured);
const heroPosts = featuredPosts.length > 0 ? featuredPosts.slice(0, 3) : posts.slice(0, 3);
const recentPosts = posts.slice(0, 6);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <section class="relative overflow-hidden rounded-[2rem] border border-pink-200/50 bg-gradient-to-br from-pink-100 via-white to-purple-100 px-6 py-12 dark:border-purple-500/20 dark:from-pink-950/60 dark:via-[#151524] dark:to-purple-950/50 sm:px-10">
    <div class="motion-orb absolute -right-8 top-8 h-28 w-28 rounded-full bg-pink-400/20 blur-3xl dark:bg-pink-500/20"></div>
    <div class="motion-glow absolute -left-10 bottom-0 h-32 w-32 rounded-full bg-purple-400/15 blur-3xl dark:bg-purple-500/20"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(236,72,153,0.18),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(168,85,247,0.16),transparent_30%)]"></div>
    <div class="relative flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4 sm:gap-5">
        <img
          data-reveal
          class="reveal-scale h-20 w-20 rounded-3xl object-cover shadow-[0_12px_28px_rgba(236,72,153,0.12)] sm:h-24 sm:w-24"
          style="--reveal-delay:60ms"
          src={siteConfig.author.avatar}
          alt={siteConfig.author.name}
        />
        <div class="space-y-3">
          <h1 data-reveal class="reveal text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl" style="--reveal-delay:110ms">
            你好，我是 {siteConfig.author.name}
          </h1>
          <p data-reveal class="reveal max-w-xl text-sm leading-7 text-gray-700 dark:text-gray-300 sm:text-base" style="--reveal-delay:160ms">
            {siteConfig.author.intro}
          </p>
        </div>
      </div>
      <div class="flex flex-wrap gap-3 sm:justify-end">
        <a data-reveal href="/posts" class="interactive-link reveal rounded-full bg-gradient-to-r from-pink-500 to-purple-500 px-6 py-3 font-medium text-white hover:shadow-[0_12px_28px_rgba(236,72,153,0.2)]" style="--reveal-delay:210ms">
          查看文章
        </a>
        <a data-reveal href="/about" class="interactive-link reveal rounded-full border border-gray-200 bg-white/80 px-6 py-3 font-medium text-gray-700 hover:border-pink-300 hover:text-pink-500 hover:shadow-[0_10px_24px_rgba(236,72,153,0.08)] dark:border-gray-700 dark:bg-gray-900/70 dark:text-gray-200 dark:hover:border-purple-400 dark:hover:text-purple-300 dark:hover:shadow-[0_10px_24px_rgba(168,85,247,0.08)]" style="--reveal-delay:260ms">
          关于我
        </a>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div data-reveal class="section-title reveal">
      <span class="section-title-accent"></span>
      <h2>精选文章</h2>
    </div>
    {heroPosts.length === 0 ? (
      <div data-reveal class="glass-card reveal p-8 text-center text-gray-500 dark:text-gray-400">还没有文章哦</div>
    ) : (
      <div class="grid gap-6 lg:grid-cols-3">
        {heroPosts.map((post, index) => (
          <div style={`--reveal-delay:${index * 70}ms`}>
            <PostCard post={post} />
          </div>
        ))}
      </div>
    )}
  </section>

  <section class="pb-8">
    <div data-reveal class="section-title reveal">
      <span class="section-title-accent"></span>
      <h2>最近更新</h2>
    </div>
    <div class="grid gap-6">
      {recentPosts.map((post, index) => (
        <div style={`--reveal-delay:${index * 55}ms`}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
    {posts.length > 6 && (
      <div class="mt-6">
        <a data-reveal href="/posts" class="interactive-link reveal inline-flex rounded-full border border-gray-200 px-5 py-2.5 text-sm font-medium text-gray-700 hover:border-pink-300 hover:text-pink-500 hover:shadow-[0_10px_24px_rgba(236,72,153,0.08)] dark:border-gray-700 dark:text-gray-200 dark:hover:border-purple-400 dark:hover:text-purple-300 dark:hover:shadow-[0_10px_24px_rgba(168,85,247,0.08)]">
          查看全部文章
        </a>
      </div>
    )}
  </section>
</BaseLayout>
