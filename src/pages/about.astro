---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  { name: 'GitHub', url: 'https://github.com/Bad0RANG3', icon: 'github' },
  { name: 'X', url: 'https://x.com/Bad0RANG3', icon: 'x' },
  { name: 'Instagram', url: 'https://instagram.com/Bad0RANG3ovo', icon: 'instagram' },
  { name: 'Telegram', url: 'https://t.me/Bad0RANG3', icon: 'telegram' },
  { name: 'YouTube', url: 'https://youtube.com/Bad0RANG3', icon: 'youtube' },
  { name: 'Bilibili', url: 'https://space.bilibili.com/482966540', icon: 'bilibili' },
  { name: 'Email', url: 'mailto:badorangeovo@outlook.com', icon: 'mail' },
];

const techStack = ['HTML5', 'CSS3', 'JavaScript', 'Python', 'Java', 'C++', 'C#', 'Git', 'Docker', 'Vue.js', 'Tailwind CSS', 'Webpack', 'Flask', 'PyTorch', 'Spring Boot', 'Maven', 'Qt'];
const devTools = ['Arch Linux', 'Windows 11', 'VS Code', 'IDA Pro', 'Wireshark', 'Unity', 'After Effects', 'Photoshop'];
const games = ['Minecraft', 'CS2'];
---

<BaseLayout title="关于 - Bad0RANG3's Blog">
  <div class="space-y-8">
    <div class="bg-white dark:bg-[#1a1a2e] rounded-2xl p-8 border border-slate-200/80 dark:border-slate-700/50">
      <div class="flex items-start gap-6">
        <img src="/src/HP.png" alt="Avatar" class="w-24 h-24 rounded-2xl object-cover border-4 border-white dark:border-slate-700 shadow-lg">
        <div class="flex-1">
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-3">
            👋 Hi, there!
          </h1>
          <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">欢迎和我交朋友 ^-^</p>
          <div>
            <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400 mb-4 uppercase tracking-wider">Social Media</h2>
            <div class="flex flex-wrap gap-3">
              {socials.map(s => (
                <a href={s.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 dark:bg-slate-800/50 hover:bg-gradient-to-r hover:from-blue-500/10 hover:to-purple-500/10 hover:text-blue-500 dark:hover:text-purple-400 transition-all duration-300 text-sm font-medium">
                  {s.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white dark:bg-[#1a1a2e] rounded-2xl p-8 border border-slate-200/80 dark:border-slate-700/50">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-gradient-to-b from-blue-500 to-purple-500 rounded-full"></span>
        Tech Stack
      </h2>
      <div class="flex flex-wrap gap-2">
        {techStack.map(tech => (
          <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/50 text-sm font-medium text-slate-700 dark:text-slate-300">{tech}</span>
        ))}
      </div>

      <h2 class="text-xl font-semibold text-slate-900 dark:text-white mt-8 mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-gradient-to-b from-blue-500 to-purple-500 rounded-full"></span>
        Development Tools
      </h2>
      <div class="flex flex-wrap gap-2">
        {devTools.map(tool => (
          <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/50 text-sm font-medium text-slate-700 dark:text-slate-300">{tool}</span>
        ))}
      </div>

      <h2 class="text-xl font-semibold text-slate-900 dark:text-white mt-8 mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-gradient-to-b from-blue-500 to-purple-500 rounded-full"></span>
        Games
      </h2>
      <div class="flex flex-wrap gap-2">
        {games.map(game => (
          <span class="px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800/50 text-sm font-medium text-slate-700 dark:text-slate-300">{game}</span>
        ))}
      </div>
    </div>

    <div class="bg-white dark:bg-[#1a1a2e] rounded-2xl p-8 border border-slate-200/80 dark:border-slate-700/50">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-gradient-to-b from-blue-500 to-purple-500 rounded-full"></span>
        Mood
      </h2>
      <div class="bg-[#1a1a2e] dark:bg-[#0f0f1a] rounded-xl p-4 overflow-x-auto">
        <pre class="text-green-400 text-sm"><code>#include &lt;iostream&gt;
int main() &#123;
    while (true) &#123;
        std::cout &lt;&lt; "我喜欢你" &lt;&lt; std::endl;
    &#125;
    return 0;
&#125;</code></pre>
      </div>
    </div>

    <div class="bg-white dark:bg-[#1a1a2e] rounded-2xl p-8 border border-slate-200/80 dark:border-slate-700/50">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-gradient-to-b from-blue-500 to-purple-500 rounded-full"></span>
        Personal Quotes
      </h2>
      <div class="space-y-3">
        <p class="text-slate-600 dark:text-slate-400 italic">"四大皆空😡😡（指钱包、微信、支付宝和Paypal）"</p>
        <p class="text-slate-600 dark:text-slate-400 italic">"愿意和我组一辈子乐队吗？"</p>
        <p class="text-slate-600 dark:text-slate-400 italic">"质疑屎山，理解屎山，制造屎山"</p>
      </div>
    </div>
  </div>
</BaseLayout>
