---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  { name: 'GitHub', url: 'https://github.com/Bad0RANG3' },
  { name: 'X', url: 'https://x.com/Bad0RANG3' },
  { name: 'Telegram', url: 'https://t.me/Bad0RANG3' },
];

const techStack = ['HTML5', 'CSS3', 'JavaScript', 'Python', 'Java', 'C++', 'Git', 'Docker', 'Vue.js', 'Tailwind CSS', 'Flask', 'Spring Boot'];
const devTools = ['Arch Linux', 'Windows 11', 'VS Code', 'IDA Pro', 'Wireshark', 'Unity', 'After Effects'];
const games = ['Minecraft', 'CS2'];
---

<BaseLayout title="关于">
  <div class="space-y-6">
    <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
      <div class="flex items-start gap-6">
        <img src="/HP.png" alt="Avatar" class="w-20 h-20 rounded-xl object-cover">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">👋 Hi, there!</h1>
          <p class="text-gray-600 dark:text-gray-300 mb-4">欢迎和我交朋友 ^-^</p>
          <div class="flex flex-wrap gap-2">
            {socials.map(s => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="px-3 py-1 text-sm rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-primary/10 hover:text-primary dark:hover:bg-secondary/10 dark:hover:text-secondary transition-colors">
                {s.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">技术栈</h2>
      <div class="flex flex-wrap gap-2">
        {techStack.map(tech => (
          <span class="px-2 py-1 text-sm rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">{tech}</span>
        ))}
      </div>
    </div>

    <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">开发工具</h2>
      <div class="flex flex-wrap gap-2">
        {devTools.map(tool => (
          <span class="px-2 py-1 text-sm rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">{tool}</span>
        ))}
      </div>
    </div>

    <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">游戏</h2>
      <div class="flex flex-wrap gap-2">
        {games.map(game => (
          <span class="px-2 py-1 text-sm rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">{game}</span>
        ))}
      </div>
    </div>

    <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">语录</h2>
      <div class="space-y-2 text-gray-600 dark:text-gray-400 italic">
        <p>"四大皆空😡😡（指钱包、微信、支付宝和Paypal）"</p>
        <p>"愿意和我组一辈子乐队吗？"</p>
        <p>"质疑屎山，理解屎山，制造屎山"</p>
      </div>
    </div>
  </div>
</BaseLayout>
