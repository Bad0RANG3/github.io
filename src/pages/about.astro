---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  { name: 'GitHub', url: 'https://github.com/Bad0RANG3' },
  { name: 'X', url: 'https://x.com/Bad0RANG3' },
  { name: 'Telegram', url: 'https://t.me/Bad0RANG3' },
  { name: 'Email', url: 'mailto:bad0rang3@email.com' },
  { name: 'BiliBili', url: 'https://space.bilibili.com/482966540' },
  { name: 'Instagram', url: 'https://www.instagram.com' },
];

const techStack = ['HTML5', 'CSS3', 'JavaScript', 'Python', 'Java', 'C++', 'Git', 'Docker', 'Vue.js', 'Tailwind CSS', 'Flask', 'Spring Boot'];
const devTools = ['Arch Linux', 'Windows 11', 'VS Code', 'IDA Pro', 'Wireshark', 'Unity', 'After Effects'];
const games = ['Minecraft', 'CS2'];
---

<BaseLayout title="关于">
  <div class="max-w-3xl mx-auto space-y-6">
    <div class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <div class="flex items-start gap-6">
        <img src="/HP.png" alt="Avatar" class="w-20 h-20 rounded-xl object-cover flex-shrink-0">
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">👋 Hi, there!</h1>
          <p class="text-gray-600 dark:text-gray-300 mb-4">欢迎和我交朋友 ^-^</p>
          <div class="flex flex-wrap gap-2">
            {socials.map(s => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 text-sm rounded-lg bg-gradient-to-r from-pink-500/10 to-purple-500/10 text-pink-600 dark:text-pink-400 hover:from-pink-500/20 hover:to-purple-500/20 transition-all border border-pink-500/20 dark:border-pink-400/20">
                {s.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">💻 技术栈</h2>
      <div class="flex flex-wrap gap-2">
        {techStack.map(tech => (
          <span class="px-3 py-1 text-sm rounded-full bg-gradient-to-r from-pink-500/10 to-purple-500/10 text-gray-700 dark:text-gray-300 border border-pink-500/20 dark:border-purple-500/20">{tech}</span>
        ))}
      </div>
    </div>

    <div class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">🔨 开发工具</h2>
      <div class="flex flex-wrap gap-2">
        {devTools.map(tool => (
          <span class="px-3 py-1 text-sm rounded-full bg-gradient-to-r from-pink-500/10 to-purple-500/10 text-gray-700 dark:text-gray-300 border border-pink-500/20 dark:border-purple-500/20">{tool}</span>
        ))}
      </div>
    </div>

    <div class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">🎮 游戏</h2>
      <div class="flex flex-wrap gap-2">
        {games.map(game => (
          <span class="px-3 py-1 text-sm rounded-full bg-gradient-to-r from-pink-500/10 to-purple-500/10 text-gray-700 dark:text-gray-300 border border-pink-500/20 dark:border-purple-500/20">{game}</span>
        ))}
      </div>
    </div>

    <div class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">🌈 语录</h2>
      <div class="space-y-3 text-gray-600 dark:text-gray-400 italic">
        <p>"四大皆空😡😡（指钱包、微信、支付宝和Paypal）"</p>
        <p>"欢迎和我交朋友^-^"</p>
        <p>"愿意和我组一辈子乐队吗？"</p>
        <p>"质疑屎山，理解屎山，制造屎山"</p>
      </div>
    </div>
  </div>
</BaseLayout>
