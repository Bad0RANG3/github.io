---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const createIcon = (paths: string[], viewBox = '0 0 24 24'): string => {
  const pathMarkup = paths.map((path) => '<path d="' + path + '" />').join('');

  return '<svg viewBox="' + viewBox + '" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="h-5 w-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">' + pathMarkup + '</svg>';
};

const icons = {
  spark: createIcon(['M12 3v3', 'M12 18v3', 'M3 12h3', 'M18 12h3', 'M6.5 6.5l2.2 2.2', 'M15.3 15.3l2.2 2.2', 'M17.5 6.5l-2.2 2.2', 'M8.7 15.3l-2.2 2.2']),
  branch: createIcon(['M6 5a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z', 'M18 3a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z', 'M9 7h5a2 2 0 0 1 2 2v2', 'M9 7v9a3 3 0 0 0 3 3h4', 'M18 17a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z']),
  x: createIcon(['M6 5l12 14', 'M18 5L6 19']),
  camera: createIcon(['M4 8a3 3 0 0 1 3-3h2l1.3-1.8h3.4L15 5h2a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V8Z', 'M12 16.5a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z', 'M17 8.5h.01']),
  music: createIcon(['M14 5v8.5a3.5 3.5 0 1 1-2-3.2', 'M14 7.5c1.3 1 2.8 1.6 4.5 1.8']),
  mail: createIcon(['M4 7h16v10H4z', 'M4.5 7.5 12 13l7.5-5.5']),
  send: createIcon(['M5 12h13', 'M13 5l7 7-7 7']),
  play: createIcon(['M5 8.5a2.5 2.5 0 0 1 2.5-2.5h9A2.5 2.5 0 0 1 19 8.5v7a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 5 15.5v-7Z', 'M10 9.5l5 3-5 3v-6Z']),
  screen: createIcon(['M5 7h14v10H5z', 'M9 3 7 7', 'M15 3l2 4', 'M10 11h.01', 'M14 11h.01', 'M10 15c1-.8 3-.8 4 0']),
  terminal: createIcon(['M4 5h16v14H4z', 'M8 9l3 3-3 3', 'M13 15h3']),
  code: createIcon(['M9 8 5 12l4 4', 'M15 8l4 4-4 4', 'M13 5l-2 14']),
  brush: createIcon(['M14 5l5 5', 'M13 6 6 13a3 3 0 1 0 4 4l7-7', 'M5 19c-1 1-2.4 1.4-3 1 .1-.6.5-2 1.5-3']),
  server: createIcon(['M4 6h16v5H4z', 'M4 13h16v5H4z', 'M8 8.5h.01', 'M8 15.5h.01', 'M12 8.5h5', 'M12 15.5h5']),
  cube: createIcon(['M12 3 19 7 12 11 5 7 12 3Z', 'M19 7v10l-7 4-7-4V7', 'M12 11v10']),
  wind: createIcon(['M4 9h11a3 3 0 1 0-3-3', 'M4 12h15', 'M4 15h12a2.5 2.5 0 1 1-2.5 2.5']),
  brain: createIcon(['M9 8a3 3 0 0 1 6 0v8a3 3 0 0 1-6 0V8Z', 'M9 10H7a2 2 0 1 1 0-4h2', 'M15 10h2a2 2 0 1 0 0-4h-2', 'M9 14H7a2 2 0 1 0 0 4h2', 'M15 14h2a2 2 0 1 1 0 4h-2']),
  chip: createIcon(['M9 9h6v6H9z', 'M9 1v3', 'M15 1v3', 'M9 20v3', 'M15 20v3', 'M1 9h3', 'M1 15h3', 'M20 9h3', 'M20 15h3']),
  monitor: createIcon(['M4 6h16v10H4z', 'M9 20h6', 'M12 16v4']),
  gamepad: createIcon(['M7 10h10a4 4 0 0 1 3.8 5.3l-.6 1.8a1.8 1.8 0 0 1-2.9.8L15 16H9l-2.3 1.9a1.8 1.8 0 0 1-2.9-.8l-.6-1.8A4 4 0 0 1 7 10Z', 'M8.5 14h3', 'M10 12.5v3', 'M15.5 13.5h.01', 'M17.5 15.5h.01']),
  crosshair: createIcon(['M12 3v3', 'M12 18v3', 'M3 12h3', 'M18 12h3', 'M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z']),
  film: createIcon(['M4 7h16v10H4z', 'M8 7v10', 'M16 7v10', 'M4 11h4', 'M16 11h4']),
  cpu: createIcon(['M8 8h8v8H8z', 'M12 2v3', 'M12 19v3', 'M2 12h3', 'M19 12h3', 'M5 5l2 2', 'M17 17l2 2', 'M17 7l2-2', 'M5 19l2-2']),
  quote: createIcon(['M9 10H6v3a4 4 0 0 0 4 4', 'M18 10h-3v3a4 4 0 0 0 4 4']),
  heart: createIcon(['M12 20s-7-4.3-7-10a4 4 0 0 1 7-2.4A4 4 0 0 1 19 10c0 5.7-7 10-7 10Z']),
  link: createIcon(['M10 14 8 16a3 3 0 1 1-4-4l2-2', 'M14 10l2-2a3 3 0 1 1 4 4l-2 2', 'M8 12h8']),
};

type IconKey = keyof typeof icons;

const socialMeta = {
  GitHub: { icon: 'branch', description: '开源仓库、折腾记录和项目现场。' },
  X: { icon: 'x', description: '日常动态、碎碎念和随手记录。' },
  Instagram: { icon: 'camera', description: '一些生活画面和灵感存档。' },
  抖音: { icon: 'music', description: '短视频更新和轻量分享。' },
  Email: { icon: 'mail', description: '更正式一些的联系入口。' },
  Telegram: { icon: 'send', description: '适合即时聊天和快速交流。' },
  YouTube: { icon: 'play', description: '视频内容、收藏和灵感来源。' },
  BiliBili: { icon: 'screen', description: '主页据点，偶尔也会长期停留。' },
};

const techMeta = {
  HTML5: { icon: 'code', tag: 'Web' },
  CSS3: { icon: 'brush', tag: '样式' },
  JavaScript: { icon: 'code', tag: '脚本' },
  Python: { icon: 'terminal', tag: '语言' },
  Java: { icon: 'server', tag: '语言' },
  'C++': { icon: 'chip', tag: '语言' },
  'C#': { icon: 'chip', tag: '语言' },
  Git: { icon: 'branch', tag: '协作' },
  Docker: { icon: 'cube', tag: '容器' },
  'Vue.js': { icon: 'wind', tag: '框架' },
  'Tailwind CSS': { icon: 'wind', tag: '样式' },
  Webpack: { icon: 'cube', tag: '构建' },
  Flask: { icon: 'server', tag: '后端' },
  PyTorch: { icon: 'brain', tag: 'AI' },
  'Spring Boot': { icon: 'server', tag: '后端' },
};

const toolMeta = {
  'Arch Linux': { icon: 'monitor', tag: '系统' },
  'Windows 11': { icon: 'monitor', tag: '系统' },
  'VS Code': { icon: 'code', tag: '文本编辑器' },
  'IDA Pro': { icon: 'chip', tag: '逆向' },
  'Wireshark': { icon: 'screen', tag: '抓包' },
  Unity: { icon: 'cube', tag: '引擎' },
  'After Effects': { icon: 'film', tag: '影像' },
};

const interestMeta = {
  Minecraft: { icon: 'cube', description: '从来没觉得做机器开心过。' },
  CS2: { icon: 'crosshair', description: '不打FPS哪里算有过青春？' },
  视频特效: { icon: 'film', description: '实际上我并不会设计。' },
  折腾硬件与软件: { icon: 'cpu', description: '对设备、系统和工具链都有兴趣。' },
};

const supportMeta = {
  '给我发邮件': { icon: 'mail', description: '聊合作、聊天或单纯打个招呼。' },
  'GitHub 关注': { icon: 'branch', description: '看我在写什么、折腾什么。' },
  'BiliBili 主页': { icon: 'play', description: '视频内容和长期据点入口。' },
};

const heroKeywords: { icon: IconKey; label: string }[] = [
  { icon: 'film', label: siteConfig.about.interests[2] ?? '视频特效' },
  { icon: 'cpu', label: siteConfig.about.interests[3] ?? '软件折腾' },
  { icon: 'spark', label: '持续学习中' },
];

const heroStats: { icon: IconKey; label: string; value: string; hint: string }[] = [
  { icon: 'code', label: '技术条目', value: `${siteConfig.about.techStack.length}`, hint: '常用技术栈' },
  { icon: 'heart', label: '兴趣标签', value: `${siteConfig.about.interests.length}`, hint: '游戏 / 创作 / 折腾' },
];

const socialCards = siteConfig.socials.map((social): { name: string; url: string; icon: IconKey; description: string } => ({
  ...social,
  icon: (socialMeta[social.name]?.icon ?? 'link') as IconKey,
  description: socialMeta[social.name]?.description ?? '在这里也能找到我。',
}));

const techCards = siteConfig.about.techStack.map((tech): { name: string; url: string; icon: IconKey; tag: string } => ({
  ...tech,
  icon: (techMeta[tech.name]?.icon ?? 'code') as IconKey,
  tag: techMeta[tech.name]?.tag ?? '技术',
}));

const toolCards = siteConfig.about.devTools.map((tool): { name: string; url: string; icon: IconKey; tag: string } => ({
  ...tool,
  icon: (toolMeta[tool.name]?.icon ?? 'monitor') as IconKey,
  tag: toolMeta[tool.name]?.tag ?? '工具',
}));

const interestCards = siteConfig.about.interests.map((interest): { name: string; icon: IconKey; description: string } => ({
  name: interest,
  icon: (interestMeta[interest]?.icon ?? 'spark') as IconKey,
  description: interestMeta[interest]?.description ?? '让我愿意持续投入时间的东西。',
}));

const supportCards = siteConfig.about.support.map((item): { label: string; url: string; icon: IconKey; description: string } => ({
  ...item,
  icon: (supportMeta[item.label]?.icon ?? 'link') as IconKey,
  description: supportMeta[item.label]?.description ?? '从这里继续向前。',
}));

const statusLines = siteConfig.about.currentStatus.split('\n');
---

<BaseLayout title="关于" description="了解博主和常用技术栈。">
  <div class="mx-auto max-w-5xl space-y-6">
    <section data-reveal class="reveal relative overflow-hidden rounded-[2rem] border border-pink-200/50 bg-gradient-to-br from-pink-100 via-white to-purple-100 px-6 py-8 dark:border-purple-500/20 dark:from-pink-950/60 dark:via-[#151524] dark:to-purple-950/50 sm:px-8 sm:py-10">
      <div class="motion-orb absolute -right-8 top-8 h-28 w-28 rounded-full bg-pink-400/20 blur-3xl dark:bg-pink-500/20"></div>
      <div class="motion-glow absolute -left-10 bottom-0 h-32 w-32 rounded-full bg-purple-400/15 blur-3xl dark:bg-purple-500/20"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(236,72,153,0.18),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(168,85,247,0.16),transparent_30%)]"></div>

      <div class="relative grid gap-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div class="space-y-6">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
            <img
              data-reveal
              class="reveal-scale h-24 w-24 rounded-[1.75rem] object-cover shadow-[0_16px_36px_rgba(236,72,153,0.14)] sm:h-28 sm:w-28"
              style="--reveal-delay:60ms"
              src={siteConfig.author.avatar}
              alt={siteConfig.author.name}
            />
            <div class="flex-1">
              <p data-reveal class="reveal text-sm font-medium uppercase tracking-[0.3em] text-pink-600 dark:text-pink-300" style="--reveal-delay:90ms">About</p>
              <h1 data-reveal class="reveal mt-3 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl" style="--reveal-delay:140ms">{siteConfig.about.greeting}</h1>
              <p data-reveal class="reveal mt-2 text-base text-gray-600 dark:text-gray-300 sm:text-lg" style="--reveal-delay:190ms">{siteConfig.about.subtitle}</p>
              <p data-reveal class="reveal mt-4 max-w-2xl leading-7 text-gray-700 dark:text-gray-300" style="--reveal-delay:240ms">{siteConfig.author.intro}</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            {heroKeywords.map((item, index) => (
              <span
                data-reveal
                style={`--reveal-delay:${280 + index * 45}ms`}
                class="reveal inline-flex items-center gap-2 rounded-full border border-white/60 bg-white/70 px-4 py-2 text-sm text-gray-700 shadow-[0_10px_24px_rgba(236,72,153,0.08)] backdrop-blur-sm dark:border-white/10 dark:bg-gray-900/55 dark:text-gray-200"
              >
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons[item.icon]}></span>
                {item.label}
              </span>
            ))}
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
          {heroStats.map((item, index) => (
            <div
              data-reveal
              style={`--reveal-delay:${340 + index * 60}ms`}
              class="reveal rounded-3xl border border-white/60 bg-white/70 p-4 shadow-[0_14px_30px_rgba(236,72,153,0.08)] backdrop-blur-sm dark:border-white/10 dark:bg-gray-900/60"
            >
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons[item.icon]}></span>
                <div>
                  <p class="text-xs font-medium uppercase tracking-[0.28em] text-gray-400 dark:text-gray-500">{item.label}</p>
                  <p class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white">{item.value}</p>
                  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{item.hint}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
      <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Online</p>
            <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">社交坐标</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">想聊天、看动态、翻仓库，或者单纯路过，这里都能找到我。</p>
          </div>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons.spark}></span>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {socialCards.map((social, index) => (
            <a
              data-reveal
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              style={`--reveal-delay:${index * 45}ms`}
              class="interactive-link reveal group rounded-3xl border border-pink-500/15 bg-gradient-to-r from-pink-500/8 to-purple-500/8 p-4 hover:border-pink-300/35 hover:bg-pink-50/65 hover:shadow-[0_12px_28px_rgba(236,72,153,0.08)] dark:border-purple-400/15 dark:hover:border-purple-400/35 dark:hover:bg-gray-800/60"
            >
              <div class="flex items-start gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/80 text-pink-500 shadow-sm dark:bg-gray-900/70 dark:text-purple-300" set:html={icons[social.icon]}></span>
                <div class="min-w-0">
                  <p class="font-medium text-gray-900 dark:text-white">{social.name}</p>
                  <p class="mt-1 text-sm leading-6 text-gray-500 dark:text-gray-400">{social.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7" style="--reveal-delay:80ms">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Now</p>
            <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">当前状态</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">如果把最近的状态写成一小段程序，大概会像现在这样。</p>
          </div>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons.terminal}></span>
        </div>

        <div class="overflow-hidden rounded-[1.4rem] border border-gray-800 bg-[#0c1020] shadow-[0_18px_38px_rgba(15,23,42,0.2)]">
          <div class="flex items-center justify-between border-b border-white/5 px-4 py-3 text-xs text-gray-400">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-rose-400"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </div>
            <span>status.cpp</span>
          </div>
          <div class="space-y-2 px-4 py-4 font-mono text-[0.82rem] leading-7 sm:text-sm">
            {statusLines.map((line, index) => (
              <div class="grid grid-cols-[auto_1fr] gap-4">
                <span class="select-none text-gray-500">{String(index + 1).padStart(2, '0')}</span>
                <code class="block whitespace-pre-wrap text-gray-100">{line || ' '}</code>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-2">
      <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Stack</p>
            <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">技术栈</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">常写、常看、或者经常顺手拿来解决问题的这些东西。</p>
          </div>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons.code}></span>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {techCards.map((tech, index) => (
            <a
              data-reveal
              href={tech.url}
              target="_blank"
              rel="noopener noreferrer"
              style={`--reveal-delay:${index * 35}ms`}
              class="interactive-link reveal group rounded-3xl border border-transparent bg-white/60 p-4 hover:border-pink-300/35 hover:bg-pink-50/65 hover:shadow-[0_10px_24px_rgba(236,72,153,0.08)] dark:bg-gray-900/40 dark:hover:border-purple-400/35 dark:hover:bg-gray-800/60"
            >
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/12 to-purple-500/12 text-pink-500 dark:text-purple-300" set:html={icons[tech.icon]}></span>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{tech.name}</p>
                  <p class="mt-1 text-xs font-medium uppercase tracking-[0.22em] text-gray-400 dark:text-gray-500">{tech.tag}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7" style="--reveal-delay:70ms">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Toolkit</p>
            <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">开发工具</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">平时最常打开的系统、编辑器、逆向和创作工具。</p>
          </div>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons.monitor}></span>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {toolCards.map((tool, index) => (
            <a
              data-reveal
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              style={`--reveal-delay:${index * 45}ms`}
              class="interactive-link reveal group rounded-3xl border border-transparent bg-white/60 p-4 hover:border-pink-300/35 hover:bg-pink-50/65 hover:shadow-[0_10px_24px_rgba(236,72,153,0.08)] dark:bg-gray-900/40 dark:hover:border-purple-400/35 dark:hover:bg-gray-800/60"
            >
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/12 to-purple-500/12 text-pink-500 dark:text-purple-300" set:html={icons[tool.icon]}></span>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{tool.name}</p>
                  <p class="mt-1 text-xs font-medium uppercase tracking-[0.22em] text-gray-400 dark:text-gray-500">{tool.tag}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>

    <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
      <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Fun</p>
            <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">兴趣与游戏</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">除了代码以外，能让我一直保持热情的几样东西。</p>
          </div>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons.gamepad}></span>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
          {interestCards.map((interest, index) => (
            <div
              data-reveal
              style={`--reveal-delay:${index * 55}ms`}
              class="reveal rounded-3xl border border-transparent bg-white/60 p-4 dark:bg-gray-900/40"
            >
              <div class="flex items-start gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/12 to-purple-500/12 text-pink-500 dark:text-purple-300" set:html={icons[interest.icon]}></span>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{interest.name}</p>
                  <p class="mt-1 text-sm leading-6 text-gray-500 dark:text-gray-400">{interest.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7" style="--reveal-delay:80ms">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Quotes</p>
            <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">语录</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">有些是玩笑，有些是心情，但都算是比较真实的自己。</p>
          </div>
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/15 to-purple-500/15 text-pink-500 dark:text-purple-300" set:html={icons.quote}></span>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          {siteConfig.about.quotes.map((quote, index) => (
            <div
              data-reveal
              style={`--reveal-delay:${index * 55}ms`}
              class="reveal rounded-3xl border border-transparent bg-white/60 p-4 dark:bg-gray-900/40"
            >
              <span class="mb-3 flex h-10 w-10 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/12 to-purple-500/12 text-pink-500 dark:text-purple-300" set:html={icons.quote}></span>
              <p class="text-sm italic leading-7 text-gray-600 dark:text-gray-300">{quote}</p>
            </div>
          ))}
        </div>
      </section>
    </div>

    <section data-reveal class="glass-card motion-surface reveal p-6 sm:p-7">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.28em] text-pink-500 dark:text-pink-300">Contact</p>
          <h2 class="mt-2 text-xl font-semibold text-gray-900 dark:text-white">Support / Contact</h2>
          <p class="mt-1 max-w-2xl text-sm leading-6 text-gray-600 dark:text-gray-400">如果你想继续聊技术、作品、灵感，或者只是想来打个招呼，就从这里开始吧。</p>
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          {supportCards.map((item, index) => (
            <a
              data-reveal
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              style={`--reveal-delay:${index * 50}ms`}
              class="interactive-link reveal rounded-3xl border border-gray-200 bg-white/70 px-4 py-4 hover:border-pink-300 hover:text-pink-500 hover:shadow-[0_12px_28px_rgba(236,72,153,0.08)] dark:border-gray-700 dark:bg-gray-900/55 dark:hover:border-purple-400 dark:hover:text-purple-300 dark:hover:shadow-[0_12px_28px_rgba(168,85,247,0.08)]"
            >
              <div class="flex items-start gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-gradient-to-br from-pink-500/12 to-purple-500/12 text-pink-500 dark:text-purple-300" set:html={icons[item.icon]}></span>
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">{item.label}</p>
                  <p class="mt-1 text-sm leading-6 text-gray-500 dark:text-gray-400">{item.description}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
