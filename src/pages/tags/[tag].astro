---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getAllTags, getPostsByTag } from '../../lib/content';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map((tag) => ({
    params: { tag },
  }));
}

const tag = decodeURIComponent(Astro.params.tag ?? '');
const posts = await getPostsByTag(tag);
---

<BaseLayout title={`标签：${tag}`} description={`查看与 ${tag} 相关的文章。`}>
  <section class="mb-10 space-y-4">
    <p data-reveal class="reveal text-sm font-medium uppercase tracking-[0.3em] text-pink-600 dark:text-pink-300">Tag archive</p>
    <div>
      <h1 data-reveal class="reveal text-4xl font-bold text-gray-900 dark:text-white" style="--reveal-delay:80ms">#{tag}</h1>
      <p data-reveal class="reveal mt-3 text-gray-600 dark:text-gray-300" style="--reveal-delay:150ms">共找到 {posts.length} 篇相关文章。</p>
    </div>
  </section>

  {posts.length === 0 ? (
    <div data-reveal class="glass-card reveal p-8 text-center text-gray-500 dark:text-gray-400">这个标签下暂时没有文章。</div>
  ) : (
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {posts.map((post, index) => (
        <div style={`--reveal-delay:${index * 70}ms`}>
          <PostCard post={post} />
        </div>
      ))}
    </div>
  )}
</BaseLayout>
