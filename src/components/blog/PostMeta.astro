---
import { formatDate, formatLongDate } from '../../lib/date';

interface Props {
  date: Date;
  updatedDate?: Date;
  centered?: boolean;
  long?: boolean;
}

const { date, updatedDate, centered = false, long = false } = Astro.props;
const formatter = long ? formatLongDate : formatDate;
---

<div class:list={['flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-400', centered && 'justify-center']}>
  <time datetime={date.toISOString()}>
    发布于 {formatter(date)}
  </time>
  {updatedDate && updatedDate.valueOf() !== date.valueOf() && (
    <time datetime={updatedDate.toISOString()}>
      更新于 {formatter(updatedDate)}
    </time>
  )}
</div>
