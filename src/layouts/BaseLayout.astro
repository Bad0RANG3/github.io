---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '分享我在软件开发、技术和生活中的想法与经验。' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" href="/ico.ico" type="image/x-icon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white dark:bg-[#0f0f1a] text-gray-800 dark:text-gray-200 min-h-screen font-sans antialiased">
  <div class="fixed inset-0 z-[-1] overflow-hidden">
    <video class="absolute inset-0 w-full h-full object-cover" autoplay loop muted playsinline preload="none">
      <source src="/bgvedio.webm" type="video/webm">
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-white/80 via-white/60 to-white dark:from-[#0f0f1a]/80 dark:via-[#0f0f1a]/60 dark:to-[#0f0f1a]" />
  </div>
  <nav class="sticky top-0 z-50 bg-white/90 dark:bg-[#1a1a2e]/90 backdrop-blur-md border-b border-gray-100 dark:border-gray-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between h-14">
        <a href="/" class="text-lg font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
          Bad0RANG3's Blog
        </a>
        <div class="flex items-center gap-1">
          <a href="/" class:list={['px-3 py-1.5 rounded-lg text-sm transition-colors', currentPath === '/' ? 'bg-gradient-to-r from-primary/10 to-secondary/10 text-primary' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800']}>
            首页
          </a>
          <a href="/about" class:list={['px-3 py-1.5 rounded-lg text-sm transition-colors', currentPath === '/about' ? 'bg-gradient-to-r from-primary/10 to-secondary/10 text-primary' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800']}>
            关于
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>

  <footer class="border-t border-gray-100 dark:border-gray-800 mt-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 text-center text-sm text-gray-500 dark:text-gray-400">
      © 2026-NOW Bad0RANG3 With ❤️
    </div>
  </footer>

  <script>
    const theme = localStorage.getItem('theme');
    if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</body>
</html>
